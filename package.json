{
  "name": "@xxlabs/pro-components",
  "version": "1.0.4",
  "description": "Fork of @ant-design/pro-components focused on cleanup and evolution",
  "keywords": [
    "admin",
    "ant-design",
    "ant-design-pro",
    "antd"
  ],
  "homepage": "https://suxiuxing.github.io/pro-components/",
  "bugs": "https://github.com/suxiuxing/pro-components",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/suxiuxing/pro-components.git"
  },
  "files": [
    "dist",
    "lib",
    "es",
    "guidelines"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "npm run build:lib && npm run build:docs",
    "build:docs": "cross-env SITE_DEPLOY='TRUE' dumi build",
    "build:lib": "tsdown",
    "dev": "dumi dev",
    "lint": "eslint --cache --ext .js,.jsx,.ts,.tsx  --fix ./ && npm run tsc",
    "prepare": "lefthook install",
    "fmt": "prettier --write \"**/**.{js,jsx,tsx,ts,less,md,yaml,json}\" --log-level warn",
    "release": "semantic-release",
    "test": "cross-env TZ=UTC vitest run",
    "test:coverage": "cross-env TZ=UTC TEST_LOG=none vitest run --coverage",
    "test:ui": "cross-env TZ=UTC vitest --ui",
    "test:update": "cross-env TZ=UTC  vitest -u",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^2.1.2",
    "@ant-design/icons": "^6.1.1",
    "@babel/runtime": "^7.29.2",
    "@ctrl/tinycolor": "^4.2.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/css": "^11.13.5",
    "@rc-component/form": "^1.8.0",
    "@rc-component/resize-observer": "^1.1.2",
    "@rc-component/table": "^1.10.0",
    "@rc-component/util": "^1.10.1",
    "@umijs/route-utils": "^4.0.3",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "lodash-es": "^4.18.1",
    "path-to-regexp": "^8.4.2",
    "react-draggable": "^4.5.0",
    "safe-stable-stringify": "^2.5.0",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@rolldown/plugin-babel": "^0.2.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash-es": "^4.17.12",
    "@types/mockjs": "^1.0.10",
    "@types/node": "^14.18.63",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-istanbul": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "antd": "^6.3.5",
    "cross-env": "^10.1.0",
    "dumi": "^2.4.23",
    "dumi-theme-antd-style": "^0.31.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "happy-dom": "^20.8.9",
    "jest-canvas-mock": "^2.5.2",
    "lefthook": "^2.1.5",
    "mockdate": "^3.0.5",
    "mockjs": "^1.1.0",
    "prettier": "^3.8.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "semantic-release": "^25.0.3",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "umi-request": "^1.4.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vite": "^8.0.8",
    "vitest": "^3.2.4",
    "xhr-mock": "^2.5.1"
  },
  "peerDependencies": {
    "antd": ">=6.3.0",
    "react": ">=19.2.5",
    "react-dom": ">=19.2.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "core-js",
      "core-js-pure",
      "esbuild",
      "lefthook"
    ]
  }
}
